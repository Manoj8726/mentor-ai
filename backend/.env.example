# MentorAI Environment Variables Template

# App Settings
APP_NAME=MentorAI
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/mentor_ai

# Security & Authentication
JWT_SECRET=supersecretjwtkeyformentorai_changeshouldbeindev
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Vector Database (ChromaDB)
CHROMA_DB_PATH=./chroma_db

# File Storage
UPLOAD_FOLDER=./uploads

# Third Party APIs
OPENAI_API_KEY=your-api-key-here
OPENAI_CHAT_MODEL=llama-3.3-70b-versatile
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=2000
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# LangSmith Tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=MentorAI
